<?xml version='1.0' encoding='utf-8'?>
<widget id="starsharp06sharp.gomoku" version="1.4.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>Gomoku</name>
    <description>A offline Gomoku Game APP</description>
    <author email="leolzheng@outlook.com" href="https://cordova.apache.org">
        Zheng Lei
    </author>
    <content src="index.html" />
    <preference name="orientation" value="landscape" />
    <platform name="android">
        <preference name="android-minSdkVersion" value="29" />
        <icon density="ldpi" src="res/icon/icon-ldpi.png" />
        <icon density="mdpi" src="res/icon/icon-mdpi.png" />
        <icon density="hdpi" src="res/icon/icon-hdpi.png" />
        <icon density="xhdpi" src="res/icon/icon-xhdpi.png" />
        <icon density="xxhdpi" src="res/icon/icon-xxhdpi.png" />
        <icon density="xxxhdpi" src="res/icon/icon-xxxhdpi.png" />
    </platform>
</widget>
